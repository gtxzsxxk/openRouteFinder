# OpenRouteFinder Configuration
# Copy to .env and customize

LISTEN_PORT=9807
METAR_UPDATE_MINUTES=15
BING_MAPS_KEY=your_key_here

# Admin key for operations dashboard (leave empty to disable)
ADMIN_KEY=

# Nav data paths (relative to project root)
NAVDAT_PATH=data/navidata_2206.map
APDAT_PATH=data/airport_2206.air
NAVDAT_CYCLE=AUTO

# Path to raw Aerosoft nav data (for pack_data.py)
LOCAL_ASDATA_PATH=/path/to/aerosoft/data

# Disable captcha validation (for testing/development)
DISABLE_CAPTCHA=false

# LRU cache size for built airport SID/STAR connections (default 1000)
AIRPORT_CONNECTION_CACHE_SIZE=1000
